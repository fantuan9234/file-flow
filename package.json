{
  "name": "file-flow",
  "version": "1.1.1",
  "description": "A minimal Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:linux": "pnpm build && electron-builder --linux",
    "test:integration": "node tests/integration.test.mjs"
  },
  "build": {
    "appId": "com.fantuan9234.fileflow",
    "productName": "FileFlow",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "!**/.vscode/*",
      "!src/*",
      "!electron.vite.config.{js,ts,mjs,cjs}",
      "!{.eslintcache,eslint.config.mjs,.prettierignore,.prettierrc.yaml,dev-app-update.yml,CHANGELOG.md,README.md}",
      "!{.env,.env.*,.npmrc,pnpm-lock.yaml}"
    ],
    "asarUnpack": [
      "resources/**"
    ],
    "extraResources": [
      {
        "from": "paddleocr-json/",
        "to": "paddleocr-json/",
        "filter": [
          "**/*",
          "!**/README.md"
        ]
      },
      {
        "from": "logs/",
        "to": "logs/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "FileFlow",
      "icon": "build/fileflow-icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FileFlow",
      "uninstallDisplayName": "FileFlow"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/fileflow-icon.icns",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "dmg": {
      "artifactName": "${name}-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/fileflow-icon.png",
      "category": "Utility"
    },
    "appImage": {
      "artifactName": "${name}-${version}.${ext}"
    },
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "fantuan9234",
      "repo": "file-flow",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/qrcode": "^1.5.6",
    "antd": "^6.3.7",
    "electron-updater": "^6.8.3",
    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "md-to-pdf": "^5.2.5",
    "paddleocrjson": "1.1.1-a",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.6",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "turndown": "^7.2.4",
    "uuid": "^14.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.0",
    "canvas": "^3.2.3",
    "docx": "^9.6.1",
    "electron": "^39.8.9",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "typescript": "^5.3.0",
    "vite": "^7.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "electron",
      "esbuild"
    ]
  }
}
